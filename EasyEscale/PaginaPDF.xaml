<Window x:Class="EasyEscale.PaginaPDF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="EasyEscale - Exportar PDF" Height="750" Width="1000"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18">
                    <MenuItem Header="Início">
                        <MenuItem Name="Ini" Header="Início" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horários" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header="Escalas Época Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="Exportar PDF" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas Guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Exportar Escala" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Selecione o Tipo:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox Name="cbP" Height="35" SelectionChanged="cbP_SelectionChanged" Margin="0,0,0,15">
                            <ComboBoxItem Content="Exames"/>
                            <ComboBoxItem Content="Epocas Especias"/>
                            <ComboBoxItem Content="Reuniões"/>
                        </ComboBox>

                        <StackPanel x:Name="st1" Visibility="Collapsed">
                            <Label Name="lbE" Content="Selecione o Evento:" Padding="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox Name="cbE" Height="35" SelectionChanged="cbE_SelectionChanged"/>
                        </StackPanel>

                        <Button Name="btnP" Click="Button_Click" Content="GERAR PDF"
                                Height="45" Background="#E67E22" Foreground="White"
                                FontSize="16" FontWeight="Bold" Cursor="Hand"
                                Visibility="Collapsed" Margin="0,20,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Dados da Escala" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock Name="Dados" FontWeight="Bold" Margin="0,0,5,0" FontSize="16" TextWrapping="Wrap"/>

                        <StackPanel x:Name="St1" Visibility="Collapsed" Margin="0,20,0,0">
                            <Border BorderBrush="#F39C12" BorderThickness="1" CornerRadius="5" Padding="20">
                                <TextBlock Name="lb1" FontSize="14" Foreground="#666" Text="Selecione uma escala para visualizar o resumo antes de exportar."/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
