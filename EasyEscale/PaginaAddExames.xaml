<Window x:Class="EasyEscale.PaginaAddExames"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="Adicionar Exames e Reuniões" Height="750" Width="1000"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="20">
                    <MenuItem Header="inicio">
                        <MenuItem Name="Ini" Header="Inicio" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horario" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar ">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header=" Escalas Epoca Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="pdf" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddSala" Header="Sala" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="Agendar Exame ou Reunião"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#2D3436" Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <Border Background="White" CornerRadius="15" Padding="40" Width="650"
                        BorderBrush="#D1D8E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Tipo" HorizontalAlignment="Center" FontSize="14" Foreground="#3498DB" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox SelectionChanged="mudou" Name="cbMuda" Height="45" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,25">
                            <ComboBoxItem Content="Exame"/>
                            <ComboBoxItem Content="Reunião"/>
                        </ComboBox>

                        <Separator Background="#EEE" Margin="0,0,0,25"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Data ocupa as duas colunas -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Text="Data" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <DatePicker Name="DP" Height="40" FontSize="16" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Hora de Início -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Hora de Início" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <ComboBox Name="CBI" Height="40" FontSize="16" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="9:00"/>
                                    <ComboBoxItem Content="9:30"/>
                                    <ComboBoxItem Content="10:00"/>
                                    <ComboBoxItem Content="10:30"/>
                                    <ComboBoxItem Content="11:00"/>
                                    <ComboBoxItem Content="11:30"/>
                                    <ComboBoxItem Content="12:00"/>
                                    <ComboBoxItem Content="12:30"/>
                                    <ComboBoxItem Content="13:00"/>
                                    <ComboBoxItem Content="13:30"/>
                                    <ComboBoxItem Content="14:00"/>
                                    <ComboBoxItem Content="14:30"/>
                                    <ComboBoxItem Content="15:00"/>
                                    <ComboBoxItem Content="15:30"/>
                                    <ComboBoxItem Content="16:00"/>
                                    <ComboBoxItem Content="16:30"/>
                                    <ComboBoxItem Content="17:00"/>
                                    <ComboBoxItem Content="17:30"/>
                                    <ComboBoxItem Content="18:00"/>
                                    <ComboBoxItem Content="18:30"/>
                                    <ComboBoxItem Content="19:00"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Hora de Término -->
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Hora de Término" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <ComboBox Name="CBT" Height="40" FontSize="16" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="9:30"/>
                                    <ComboBoxItem Content="10:00"/>
                                    <ComboBoxItem Content="10:30"/>
                                    <ComboBoxItem Content="11:00"/>
                                    <ComboBoxItem Content="11:30"/>
                                    <ComboBoxItem Content="12:00"/>
                                    <ComboBoxItem Content="12:30"/>
                                    <ComboBoxItem Content="13:00"/>
                                    <ComboBoxItem Content="13:30"/>
                                    <ComboBoxItem Content="14:00"/>
                                    <ComboBoxItem Content="14:30"/>
                                    <ComboBoxItem Content="15:00"/>
                                    <ComboBoxItem Content="15:30"/>
                                    <ComboBoxItem Content="16:00"/>
                                    <ComboBoxItem Content="16:30"/>
                                    <ComboBoxItem Content="17:00"/>
                                    <ComboBoxItem Content="17:30"/>
                                    <ComboBoxItem Content="18:00"/>
                                    <ComboBoxItem Content="18:30"/>
                                    <ComboBoxItem Content="19:00"/>
                                    <ComboBoxItem Content="19:30"/>
                                    <ComboBoxItem Content="20:00"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Name="Reuna" Visibility="Collapsed" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Turma" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                    <ComboBox Name="CBTurma" Height="40" FontSize="16" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Sala" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                    <ComboBox Name="CBSala" Height="40" FontSize="16" VerticalContentAlignment="Center" IsEditable="True"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Name="Exa1" Visibility="Collapsed" Margin="0,0,0,20">
                            <!-- Linha 1: Disciplina | Código do Exame -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Disciplina" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                    <ComboBox Name="CBD" Height="40" FontSize="16" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Código do Exame" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                    <TextBox Name="TxtCod" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="5,0"/>
                                </StackPanel>
                            </Grid>
                            <!-- Linha 2: Nº de Alunos | Época Especial -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nº de Alunos" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                    <TextBox Name="TxtNAlunos" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="5,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <TextBlock Text="Época Especial" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                    <CheckBox Name="check" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="5,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Button
                            Click="Button_ClickADD"

                            Content="ADICIONAR"
                                Height="55"
                                Background="#27AE60"
                                Foreground="White"
                                FontSize="18"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="0,10,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>