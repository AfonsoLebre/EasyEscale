<Window x:Class="EasyEscale.PaginaProfs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="EasyEscale - Professores" Height="750" Width="1000"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18">
                    <MenuItem Header="Início">
                        <MenuItem Name="Ini" Header="Início" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horários" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header="Escalas Época Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="Exportar PDF" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas Guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Consulta de Professores"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#2D3436" Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <Border Background="White" CornerRadius="15" Padding="40" Width="700"
                        BorderBrush="#D1D8E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Selecione um professor da lista" FontSize="14" Foreground="#3498DB" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                        <ComboBox Name="cbP" SelectionChanged="cbP_SelectionChanged" Height="45" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,30">
                           
                        </ComboBox>

                        <Separator Background="#EEE" Margin="0,0,0,30"/>

                        <Grid Name="DetailsContainer" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Estatísticas -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Name="St1">
                                    <TextBlock Text="Número de Aulas por Semana:" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="0,10"/>
                                    <TextBlock Text="Número de Vigilâncias:" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="0,10"/>
                                    <TextBlock Text="Horas Trabalhadas (Estimadas):" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="0,10"/>
                                    <TextBlock Text="Dias Disponíveis:" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="0,10"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Name="St2" HorizontalAlignment="Right">
                                    <TextBlock Name="txtAulas" Text="0" FontSize="16" FontWeight="Bold" Foreground="#2D3436" Margin="0,10"/>
                                    <TextBlock Name="txtVigias" Text="0" FontSize="16" FontWeight="Bold" Foreground="#2D3436" Margin="0,10"/>
                                    <TextBlock Name="txtHoras" Text="0h" FontSize="16" FontWeight="Bold" Foreground="#2D3436" Margin="0,10"/>
                                    <TextBlock Name="txtDias" Text="N/A" FontSize="16" FontWeight="Bold" Foreground="#2D3436" Margin="0,10"/>
                                </StackPanel>
                            </Grid>

                            <!-- BOTÃO E GRELHA -->
                            <StackPanel Grid.Row="1" Margin="0,30,0,0">
                                <Button Name="btnVerExames" Click="btnVerExames_Click" 
                                        Content="VER EXAMES AGENDADOS" 
                                        Height="45" Width="250" Background="#3498DB" Foreground="White" 
                                        FontSize="14" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Center">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <DataGrid Name="dgExamesProfessor" 
                                          AutoGenerateColumns="True" 
                                          Height="200" 
                                          Visibility="Collapsed" 
                                          Margin="0,20,0,0"
                                          IsReadOnly="True"
                                          RowBackground="#F8F9FA" AlternatingRowBackground="#EEF2F7"
                                          GridLinesVisibility="None" HeadersVisibility="Column"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Name="EmptyState" Text="Selecione um professor para ver os detalhes."
                                   FontSize="16" Foreground="#999" HorizontalAlignment="Center" Margin="0,20"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
