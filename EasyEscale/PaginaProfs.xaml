<Window x:Class="EasyEscale.PaginaProfs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="PaginaProfs" Height="450" Width="800">
    <Grid>
        <StackPanel  Height="30" VerticalAlignment="Top" Orientation="Horizontal">
            <Menu Margin="0,0,0,0" Background="Transparent">
                <MenuItem Header="inicio">

                    <MenuItem Name="Ini" Header="Inicio" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Horario" Header="Horario" Click="IR"/>
                </MenuItem>

                <MenuItem Header="Gerar ">
                    <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Epoca" Header=" Escalas Epoca Especial" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                    <MenuItem Name="Pdf" Header="pdf" Click="IR"/>
                    <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                </MenuItem>
                <MenuItem Name="EscalasGuarda" Header="Escalas guardadas" Click="IR">


                </MenuItem>
                <MenuItem Header="Adicionar">
                    <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                    <Separator/>
                    <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>

                </MenuItem>
            </Menu>
        </StackPanel>
        <StackPanel  Width="200" HorizontalAlignment="Left" Margin="0,0,70,0" Height="300" >
            <Label Content ="Lista de Professores" HorizontalContentAlignment="Center"/>
            <ComboBox Name="cbP" SelectionChanged="cbP_SelectionChanged" >
                <ComboBoxItem Content="Prof1" ></ComboBoxItem>
                <ComboBoxItem Content="Prof2" ></ComboBoxItem>
            </ComboBox>
        </StackPanel>


        <StackPanel Name="St1" Width="250" HorizontalAlignment="Right" Margin="0,0,200,0" Height="300" Visibility="Collapsed" >
            <Label Content="Numero de Aulas por Semana: " FontSize="16" FontWeight="DemiBold"/>
            <Label Content="Número de Vigilancias: " FontSize="16" FontWeight="DemiBold"/>
            <Label Content="Horas trabalhadas: " FontSize="16" FontWeight="DemiBold"/>
            <Label Content="Dias disponiveis: " FontSize="16" FontWeight="DemiBold"/>
        </StackPanel>

        <StackPanel Name="St2" Width="200" HorizontalAlignment="Right" Margin="0,0,00,0" Height="300" Visibility="Collapsed" >
            <Label Content="20 " FontSize="16" FontWeight="Bold"/>
            <Label Content="5 " FontSize="16" FontWeight="Bold"/>
            <Label Content="100 " FontSize="16" FontWeight="Bold"/>
            <Label Content="Segunda(manhã)  " FontSize="16" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
