<Window x:Class="EasyEscale.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="EasyEscale - Dashboard" Height="750" Width="1000"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18">
                    <MenuItem Header="Início">
                        <MenuItem Name="Ini" Header="Início" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horários" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header="Escalas Época Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="Exportar PDF" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas Guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddSala" Header="Sala" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="Bem-vindo à EasyEscale"
                           FontSize="48" FontWeight="Bold"
                           Foreground="#2D3436" Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Aplicação de elaboração das escalas de vigilancia para exames e Reuniões escolares"
                           FontSize="20" Foreground="#636E72" Margin="0,0,0,50"
                           HorizontalAlignment="Center"/>

                <Border Background="White" CornerRadius="20" Padding="40" Width="700"
                        BorderBrush="#D1D8E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Direction="270" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>

                    <StackPanel>
                        <Image Source="/Imagem/Logo_EasyEscale-removebg-preview.png" Height="500" Stretch="Uniform" Margin="0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
