<Window x:Class="EasyEscale.PaginaEpocaE"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"

        Title="PaginaExamesEpocaEspecial"
        Height="750"
        Width="1000"

        WindowState="Maximized"
        Background="#F0F2F5">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18">
                    <MenuItem Header="Início">
                        <MenuItem Name="Ini" Header="Início" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horários" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header="Escalas Época Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="Exportar PDF" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas Guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="50">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White"
         CornerRadius="10"
         Padding="20"
         Width="350"
         HorizontalAlignment="Left">

                <StackPanel>

                    <TextBlock Text="Selecionar Exame"
                    FontSize="20"
                    FontWeight="Bold"
                    Margin="0,0,0,10"/>

                    <ComboBox Name="cbP"
                   Height="35"
                   SelectionChanged="cbP_SelectionChanged">

                    </ComboBox>

                    <Button Name="btn1"
                 Content="Gerar Escala"
                 Click="gerar"
                 Margin="0,15,0,0"
                 Height="40"
                 Background="#27AE60"
                 Foreground="White"
                 FontWeight="Bold"
                 Visibility="Collapsed"/>

                </StackPanel>

            </Border>

            <Border Grid.Row="1"
         Background="White"
         CornerRadius="10"
         Padding="20"
         Margin="0,25,0,0"
         Visibility="Visible">

                <StackPanel>

                    <StackPanel Name="Info1"
                     Orientation="Horizontal"
                    Visibility="Collapsed">

                        <TextBlock Name="TextDados" />
                    </StackPanel>

                    <StackPanel Name="Info2"
                     Orientation="Horizontal"
                     Margin="0,10,0,0"
                     Visibility="Collapsed">

                        <TextBlock Text="Prova de:"
                        FontWeight="Bold"
                        Margin="0,0,5,0"/>

                        <TextBlock Text="Português"
                        Margin="0,0,20,0"/>

                        <TextBlock Text="Código:"
                        FontWeight="Bold"
                        Margin="0,0,5,0"/>

                        <TextBlock Text="639"
                        Margin="0,0,20,0"/>

                        <TextBlock Text="Duração:"
                        FontWeight="Bold"
                        Margin="0,0,5,0"/>

                        <TextBlock Text="120+30 min"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <Grid Grid.Row="2" Margin="0,40,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Background="White"
             CornerRadius="10"
             Padding="15">

                    <StackPanel>

                        <Label Name="lb1"
                    Content="Vigilantes Efetivos"
                    FontSize="18"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"/>

                        <DataGrid Name="DG1"
                       AutoGenerateColumns="False"
                       Height="300"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"
                       RowBackground="#F8F9FA"
                       AlternatingRowBackground="#EEF2F7"
                       GridLinesVisibility="None">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID"
                              Binding="{Binding Key}"
                              Width="50"/>

                                <DataGridTextColumn Header="Nome Professor"
                             Binding="{Binding Value}"
                            Width="*"/>

                            </DataGrid.Columns>

                        </DataGrid>

                        <Button Name="btn2"
                 Content="Guardar Escala"
                 Click="Guardar"
                 Margin="0,15,0,0"
                 Height="40"
                 Background="#27AE60"
                 Foreground="White"
                 FontWeight="Bold"
                 Visibility="Collapsed"/>

                    </StackPanel>

                </Border>

                <Rectangle Name="quadrado"
                Grid.Column="1"
                Fill="#DDD"
                Width="1"
                Visibility="Collapsed"/>

                <Border Grid.Column="2"
             Background="White"
             CornerRadius="10"
             Padding="15">

                    <StackPanel>

                        <Label Name="lb2"
                    Content="Vigilantes Suplentes"
                    FontSize="18"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"/>

                        <DataGrid Name="DG2"
                       AutoGenerateColumns="False"
                       Height="300"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"
                       RowBackground="#F8F9FA"
                       AlternatingRowBackground="#EEF2F7"
                       GridLinesVisibility="None">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID"
    Binding="{Binding Key}"
    Width="50"/>

                                <DataGridTextColumn Header="Nome Professor"
   Binding="{Binding Value}"
  Width="*"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>
    </Grid>
</Window>
