<Window x:Class="EasyEscale.PaginaAddProf"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Adicionar Professor"
        Height="700"
        Width="1000"

        WindowState="Maximized"

        Background="#F0F2F5">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="0,0,0,1">

            <Grid>

                <Menu Background="Transparent"
                      VerticalAlignment="Center"
                      Margin="10,0,0,0"
                      FontSize="20">

                    <MenuItem Header="Inicio">

                        <MenuItem Name="Ini" Header="Inicio" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horario" Click="IR"/>

                    </MenuItem>

                    <MenuItem Header="Gerar">

                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header="Escalas Epoca Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="pdf" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>

                    </MenuItem>

                    <MenuItem Name="EscalasGuarda"
                              Header="Escalas guardadas"
                              Click="IR"/>

                    <MenuItem Header="Adicionar">

                        <MenuItem Name="AddProf" Header="Professor" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>

                    </MenuItem>

                </Menu>

                <Button Content="✕"
                        HorizontalAlignment="Right"
                        Width="45"
                        Background="Transparent"
                        Foreground="#666"
                        BorderThickness="0"
                        FontSize="18"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="FecharJanela_Click">

                    <Button.Style>
                        <Style TargetType="Button">

                            <Style.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>

                            </Style.Triggers>

                        </Style>
                    </Button.Style>

                </Button>

            </Grid>

        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Grid.Column="0">

                <TextBlock Text="Cadastro de Professores"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#2D3436"
                           Margin="0,0,0,40"
                           HorizontalAlignment="Center"/>

                <Border Background="White"
                        CornerRadius="15"
                        Padding="50,40"
                        Width="650"
                        BorderBrush="#D1D8E0"
                        BorderThickness="1">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25"
                                          Direction="270"
                                          Opacity="0.1"
                                          ShadowDepth="5"/>
                    </Border.Effect>

                    <StackPanel>

                        <TextBlock Text="Nº de Processo"
                                   FontSize="16"
                                   Foreground="#555"
                                   Margin="0,0,0,8"/>

                        <TextBox Height="45"
                                 FontSize="18"
                                 Padding="10,8"
                                 Margin="0,0,0,25"
                                 BorderBrush="#CCC"
                                 VerticalContentAlignment="Center"
                                 Name="txtProc"/>

                        <TextBlock Text="Nome Completo"
                                   FontSize="16"
                                   Foreground="#555"
                                   Margin="0,0,0,8"/>

                        <TextBox Height="45"
                                 FontSize="18"
                                 Padding="10,8"
                                 Margin="0,0,0,25"
                                 BorderBrush="#CCC"
                                 VerticalContentAlignment="Center"
                                 Name="txNome"/>

                        <TextBlock Text="Endereço de E-mail"
                                   FontSize="16"
                                   Foreground="#555"
                                   Margin="0,0,0,8"/>

                        <TextBox Height="45"
                                 FontSize="18"
                                 Padding="10,8"
                                 Margin="0,0,0,40"
                                 BorderBrush="#CCC"
                                 VerticalContentAlignment="Center"
                                 Name="txMail"/>

                        <Button Content="CONCLUIR REGISTO"
                                Height="55"
                                Background="#27AE60"
                                Foreground="White"
                                FontSize="18"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Add">

                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>

                        </Button>

                    </StackPanel>

                </Border>

            </StackPanel>

            <Border Grid.Column="1"
                    Margin="40"
                    Background="White"
                    BorderBrush="#D1D8E0"
                    BorderThickness="1"
                    CornerRadius="15"
                    Padding="25">

                <StackPanel>

                    <TextBlock Text="Vincular Professores"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#333"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Height="350">

                        <StackPanel x:Name="Disciplinas"/>

                    </ScrollViewer>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>