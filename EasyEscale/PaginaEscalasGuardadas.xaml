<Window x:Class="EasyEscale.PaginaEscalasGuardadas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="PaginaEscalasGuardadas"
        Height="750"
        Width="1000"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="0,0,0,1">

            <Menu Background="Transparent"
                  VerticalAlignment="Center"
                  Margin="10,0,0,0"
                  FontSize="18">

                <MenuItem Header="inicio">
                    <MenuItem Name="Ini" Header="Inicio" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Horario" Header="Horario" Click="IR"/>
                </MenuItem>

                <MenuItem Header="Gerar">
                    <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Epoca" Header="Escalas Epoca Especial" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                    <MenuItem Name="Pdf" Header="pdf" Click="IR"/>
                    <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                </MenuItem>

                <MenuItem Name="EscalasGuarda" Header="Escalas guardadas" Click="IR"/>

                <MenuItem Header="Adicionar">
                    <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                    <Separator/>
                    <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                    <Separator/>
                    <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                </MenuItem>
            </Menu>
        </Border>

        <Grid Grid.Row="1" Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="10"
                        Padding="20"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Filtros de Pesquisa"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Selecione o Tipo:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox Name="cbP" Height="35" SelectionChanged="cbP_SelectionChanged" Margin="0,0,0,15">
                            <ComboBoxItem Content="Exames"/>
                            <ComboBoxItem Content="Epocas Especias"/>
                            <ComboBoxItem Content="Reuniões"/>
                        </ComboBox>

                        <StackPanel x:Name="st1" Visibility="Collapsed">
                            <Label Name="lbE" Content="Selecione o Evento:" Padding="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox Name="cbE" Height="35" SelectionChanged="cbP_SelectionChanged2">
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="10"
                        Padding="20"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Detalhes da Escala"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <TextBlock Name="Dados" FontWeight="Bold" Margin="0,0,5,0" FontSize="16"/>

                        <StackPanel Name="Info1" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,10">
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <Label Name="lb1"
                               Content="Vigilantes Efetivos"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>

                        <DataGrid Name="DG1"
                                  AutoGenerateColumns="False"
                                  Height="300"
                                  Visibility="Collapsed"
                                  RowBackground="#F8F9FA"
                                  AlternatingRowBackground="#EEF2F7"
                                  GridLinesVisibility="None"
                                  ItemsSource="{Binding}"
                                  RowHeight="80"
                                  FontSize="18"
                                  VerticalContentAlignment="Center">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome Professor" Binding="{Binding Value}" Width="*"/>
                                <DataGridTextColumn Header="Nº Processo" Binding="{Binding Key}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Rectangle Name="quadrado" Grid.Column="1" Fill="#E0E0E0" Width="1" Margin="0,15" Visibility="Collapsed"/>

                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <Label Name="lb2"
                               Content="Vigilantes Suplentes"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>

                        <DataGrid Name="DG2"
                                  AutoGenerateColumns="False"
                                  Height="300"
                                  Visibility="Collapsed"
                                  RowBackground="#F8F9FA"
                                  AlternatingRowBackground="#EEF2F7"
                                  GridLinesVisibility="None"
                                  ItemsSource="{Binding}"
                                  RowHeight="80"
                                  FontSize="18"
                                  VerticalContentAlignment="Center">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome Professor" Binding="{Binding Value}" Width="*"/>
                                <DataGridTextColumn Header="Nº Processo" Binding="{Binding Key}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>