<Window x:Class="EasyEscale.PaginaGRAF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="EasyEscale - Gráficos" Height="750" Width="1000"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="18">
                    <MenuItem Header="Início">
                        <MenuItem Name="Ini" Header="Início" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horários" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header="Escalas Época Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="Exportar PDF" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas Guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddSala" Header="Sala" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Análise e Gráficos"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#2D3436" Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <Border Background="White" CornerRadius="15" Padding="20" Width="1200"
                        BorderBrush="#D1D8E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Button Content="Vigilâncias por Professor" Click="AddVigiasChart" Margin="10,0" Padding="15,5" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                            <Button Content="Aulas por Professor" Click="AddAulasChart" Margin="10,0" Padding="15,5" Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
                            <Button Content="Distribuição de Cargos (Pie)" Click="AddPieChart" Margin="10,0" Padding="15,5" Background="#9B59B6" Foreground="White" FontWeight="Bold"/>
                            <Button Content="Limpar Tudo" Click="ClearCharts" Margin="10,0" Padding="15,5" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <UniformGrid x:Name="ChartsGrid" Columns="2" MinHeight="500">
                                <!-- Gráficos serão adicionados aqui -->
                            </UniformGrid>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
