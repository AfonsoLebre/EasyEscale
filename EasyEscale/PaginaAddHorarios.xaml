<Window x:Class="EasyEscale.PaginaAddHorarios"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="PaginaAddHorarios" Height="700" Width="1000"
         WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="20">
                    <MenuItem Header="inicio">
                        <MenuItem Name="Ini" Header="Inicio" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horario" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar ">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header=" Escalas Epoca Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="pdf" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddSala" Header="Sala" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="Configurar Horário"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#2D3436" Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <Border Background="White" CornerRadius="15" Padding="40" Width="600"
                        BorderBrush="#D1D8E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Selecionar Professor" FontSize="16" Foreground="#3498DB" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox Height="45" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,25" Name="CBP"/>

                        <TextBlock Text="Selecionar Disciplina" FontSize="16" Foreground="#3498DB" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox Height="45" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,25" Name="CBD">
                        </ComboBox>

                        <Separator Background="#EEE" Margin="0,0,0,25"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dia da Semana" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <ComboBox Height="40" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,20" Name="CBC">
                                    <ComboBoxItem Content="Segunda-Feira"/>
                                    <ComboBoxItem Content="Terça-Feira"/>
                                    <ComboBoxItem Content="Quarta-Feira"/>
                                    <ComboBoxItem Content="Quinta-Feira"/>
                                    <ComboBoxItem Content="Sexta-Feira"/>
                                </ComboBox>

                                <TextBlock Text="Hora de Começo" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <ComboBox Height="40" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,20" Name="CBHI">
                                    <ComboBoxItem Content="8:25"/>
                                    <ComboBoxItem Content="9:10"/>
                                    <ComboBoxItem Content="10:10"/>
                                    <ComboBoxItem Content="10:55"/>
                                    <ComboBoxItem Content="11:50"/>
                                    <ComboBoxItem Content="12:35"/>
                                    <ComboBoxItem Content="13:35"/>
                                    <ComboBoxItem Content="14:20"/>
                                    <ComboBoxItem Content="15:15"/>
                                    <ComboBoxItem Content="16:00"/>
                                    <ComboBoxItem Content="16:55"/>
                                    <ComboBoxItem Content="17:40"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Turma" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <ComboBox Height="40" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,20" Name="CBT"/>

                                <TextBlock Text="Hora de Finalização" FontSize="14" Foreground="#555" Margin="0,0,0,5"/>
                                <ComboBox Height="40" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,0,20" Name="CBHF" >
                                    <ComboBoxItem Content="9:10"/>
                                    <ComboBoxItem Content="9:55"/>
                                    <ComboBoxItem Content="10:55"/>
                                    <ComboBoxItem Content="11:40"/>
                                    <ComboBoxItem Content="12:35"/>
                                    <ComboBoxItem Content="13:20"/>
                                    <ComboBoxItem Content="14:20"/>
                                    <ComboBoxItem Content="15:05"/>
                                    <ComboBoxItem Content="16:00"/>
                                    <ComboBoxItem Content="16:45"/>
                                    <ComboBoxItem Content="17:40"/>
                                    <ComboBoxItem Content="18:25"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Button Content="REGISTAR HORÁRIO"
                                Margin="0,20,0,0"
                                Height="55"
                                Background="#27AE60"
                                Foreground="White"
                                FontSize="18"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Add">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>