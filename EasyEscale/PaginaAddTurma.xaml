<Window x:Class="EasyEscale.PaginaAddTurma"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyEscale"
        mc:Ignorable="d"
        Title="Adicionar Turma" Height="700" Width="1000" 
    WindowState="Maximized" 
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="20">
                    <MenuItem Header="inicio">
                        <MenuItem Name="Ini" Header="Inicio" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Professor" Header="Professores" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Horario" Header="Horario" Click="IR"/>
                    </MenuItem>
                    <MenuItem Header="Gerar ">
                        <MenuItem Name="Exames" Header="Escalas Exames" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Epoca" Header=" Escalas Epoca Especial" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Reuniao" Header="Escalas Reuniões" Click="IR"/>
                        <MenuItem Name="Pdf" Header="pdf" Click="IR"/>
                        <MenuItem Name="Graf" Header="Gráficos" Click="IR"/>
                    </MenuItem>
                    <MenuItem Name="EscalasGuarda" Header="Escalas guardadas" Click="IR"/>
                    <MenuItem Header="Adicionar">
                        <MenuItem Name="AddProf" Header="Professor" Click="IR" />
                        <Separator/>
                        <MenuItem Name="AddTurma" Header="Turma" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="AddHorario" Header="Horário" Click="IR"/>
                        <Separator/>
                        <MenuItem Name="Addexames" Header="Exames/Reuniões" Click="IR"/>
                    </MenuItem>
                </Menu>

                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="#666" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="FecharJanela_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="Registo de Turma" FontSize="32" FontWeight="Bold" Foreground="#2D3436" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <Border Background="White" CornerRadius="15" Padding="40" Width="800" Height="450" BorderBrush="#D1D8E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Ano Escolar" FontSize="16" Foreground="#555" Margin="0,0,0,8"/>
                            <ComboBox Name="CBA" Height="45" FontSize="18" VerticalContentAlignment="Center" Margin="0,0,0,20">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="11"/>
                                <ComboBoxItem Content="12"/>
                                
                            </ComboBox>

                            <TextBlock Text="Letra da Turma" FontSize="16" Foreground="#555" Margin="0,0,0,8"/>
                            <TextBox Name="TXL" Height="45" FontSize="18" VerticalContentAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="Ano Letivo" FontSize="16" Foreground="#555" Margin="0,0,0,8"/>
                            <ComboBox Name="CBAL" Height="45" FontSize="18" VerticalContentAlignment="Center" Margin="0,0,0,20" >
                                <ComboBoxItem Content="2025/2026"/>
                                <ComboBoxItem Content="2027/2028"/>
                                <ComboBoxItem Content="2029/2030"/>
                                <ComboBoxItem Content="2030/2031"/>
                            </ComboBox>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="#EEE" Margin="10,0" VerticalAlignment="Stretch"/>

                        <StackPanel Grid.Column="2" Margin="20,0,0,0">
                            <TextBlock Text="Vincular Professores" FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="Professores">
                                  
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>

                        <Button Click="BTNADD" Grid.ColumnSpan="3" Content="ADICIONAR TURMA" VerticalAlignment="Bottom" Margin="0,220,0,0" Height="55" Background="#27AE60" Foreground="White" FontSize="18" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>